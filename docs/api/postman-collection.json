								"value": "{{siteId}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/posts/search?q=programming&tags=tech&page=1&limit=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "posts", "search"],
